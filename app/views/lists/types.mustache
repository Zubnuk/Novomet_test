<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🚎 Типы транспорта</h2>
        <div>
            <a href="/create/create_type.php" class="btn btn-success">➕ Добавить тип</a>
            <a href="/" class="btn btn-outline-secondary">🏠 Меню</a>
        </div>
    </div>

    <div class="card shadow-sm col-md-6 mx-auto">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Наименование</th>
                    <th class="text-end px-4">Действия</th>
                </tr>
            </thead>
            <tbody>
                {{#types}}
                <tr>
                    <td>{{type_id}}</td>
                    <td><strong>{{name}}</strong></td>
                    <td class="text-end px-4">
                        <a href="/edit/edit_type.php?id={{type_id}}" 
                           class="btn btn-sm btn-outline-warning me-1" title="Редактировать">✏️</a>
                        
                        <form action="/handlers/delete/delete_type.php" method="post" class="d-inline delete-form" 
                              onsubmit="return confirm('Удалить этот тип транспорта?');">
                            <input type="hidden" name="type_id" value="{{type_id}}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить">🗑️</button>
                        </form>
                    </td>
                </tr>
                {{/types}}
            </tbody>
        </table>
    </div>
</div>