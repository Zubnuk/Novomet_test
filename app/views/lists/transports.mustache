<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🚌 Реестр транспорта</h2>
        <div>
           
            <a href="/create/create_transport.php" class="btn btn-success">➕ Добавить транспорт</a>
            <a href="/" class="btn btn-outline-secondary">🏠 Меню</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Госномер</th>
                        <th>Модель</th>
                        <th>Год</th>
                        <th>Состояние</th>
                        <th>Маршрут</th>
                        <th>Водитель</th>
                        <th>Описание</th>
                        <th class="text-end px-4">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    {{#transports}}
                    <tr>
                        <td>{{transport_id}}</td>
                        <td><span class="badge bg-dark px-2">{{plate_number}}</span></td>
                        <td><strong>{{type_name}}</strong> <small class="text-muted">{{model}}</small></td>
                        <td>{{year}}</td>
                        <td><span class="badge bg-info text-dark">{{condition_text}}</span></td>
                        <td>№{{route_number}}</td>
                        <td>{{full_name}}</td>
                        <td>{{description}}</td>
                        <td class="text-end px-4">
                          
                            <a href="/edit/edit_transport.php?id={{transport_id}}" 
                               class="btn btn-sm btn-outline-warning me-1" 
                               title="Редактировать">✏️</a>
                            
                    
                            <form action="/handlers/delete/delete_transport.php" method="post" class="d-inline delete-form" 
                                  onsubmit="return confirm('Удалить этот транспорт раз и навсегда?');">
                                <input type="hidden" name="transport_id" value="{{transport_id}}">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить">🗑️</button>
                            </form>
                        </td>
                    </tr>
                    {{/transports}}
                </tbody>
            </table>
        </div>
    </div>
</div>