<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>👨‍✈️ Список водителей</h2>
        <div>
            <a href="/create/create_driver.php" class="btn btn-success">➕ Новый водитель</a>
            <a href="/" class="btn btn-outline-secondary">🏠 Меню</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 100px;">ID</th>
                    <th>ФИО водителя</th>
                    <th class="text-end px-4">Действия</th>
                </tr>
            </thead>
            <tbody>
                {{#drivers}}
                <tr>
                    <td>{{driver_id}}</td>
                    <td><strong>{{full_name}}</strong></td>
                    <td class="text-end px-4">
                        <a href="/edit/edit_driver.php?id={{driver_id}}" 
                           class="btn btn-sm btn-outline-warning me-1" title="Редактировать">✏️</a>
                        
                        <form action="/handlers/delete/delete_driver.php" method="post" class="d-inline delete-form" 
                              onsubmit="return confirm('Уволить этого водителя?');">
                            <input type="hidden" name="driver_id" value="{{driver_id}}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить">🗑️</button>
                        </form>
                    </td>
                </tr>
                {{/drivers}}
            </tbody>
        </table>
    </div>
</div>