<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🔄 Схемы движения</h2>
        <div>
            <a href="/create/create_route_stop.php" class="btn btn-success">➕ Привязать остановку</a>
            <a href="/" class="btn btn-outline-secondary">🏠 Меню</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <table class="table table-sm table-bordered table-hover align-middle mb-0">
            <thead class="table-info">
                <tr>
                    <th class="text-center">Маршрут</th>
                    <th class="text-center">Порядок</th>
                    <th>Название остановки</th>
                    <th class="text-end px-4">Действия</th>
                </tr>
            </thead>
            <tbody>
                {{#route_stops}}
                <tr>
                    <td class="text-center fw-bold">№ {{route_number}}</td>
                    <td class="text-center"><span class="badge rounded-pill bg-secondary text-white">{{stop_order}}</span></td>
                    <td>{{stop_name}}</td>
                    <td class="text-end px-4">
                        <!-- Твоя ссылка для редактирования связи -->
                        <a href="/edit/edit_route_stop.php?route_id={{route_id}}&stop_id={{stop_id}}" 
                           class="btn btn-sm btn-outline-warning me-1" title="Редактировать">✏️</a>
                        
                        <!-- Твоя форма для удаления связи по двум ID -->
                        <form action="/handlers/delete/delete_route_stop.php" method="post" class="d-inline delete-form" 
                              onsubmit="return confirm('Удалить эту остановку из маршрута?');">
                            <input type="hidden" name="route_id" value="{{route_id}}">
                            <input type="hidden" name="stop_id" value="{{stop_id}}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить">🗑️</button>
                        </form>
                    </td>
                </tr>
                {{/route_stops}}
            </tbody>
        </table>
    </div>
</div>