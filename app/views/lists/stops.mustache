<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📍 Справочник остановок</h2>
        <div>
            <a href="/create/create_stop.php" class="btn btn-success">➕ Добавить остановку</a>
            <a href="/" class="btn btn-outline-secondary">🏠 Меню</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Название</th>
                    <th>Широта</th>
                    <th>Долгота</th>
                    <th class="text-end px-4">Действия</th>
                </tr>
            </thead>
            <tbody>
                {{#stops}}
                <tr>
                    <td><strong>{{name}}</strong></td>
                    <td><code>{{latitude}}</code></td>
                    <td><code>{{longitude}}</code></td>
                    <td class="text-end px-4">
                        <a href="/edit/edit_stop.php?id={{stop_id}}" 
                           class="btn btn-sm btn-outline-warning me-1" title="Редактировать">✏️</a>
                        
                        <form action="/handlers/delete/delete_stop.php" method="post" class="d-inline delete-form" 
                              onsubmit="return confirm('Удалить эту остановку?');">
                            <input type="hidden" name="stop_id" value="{{stop_id}}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить">🗑️</button>
                        </form>
                    </td>
                </tr>
                {{/stops}}
            </tbody>
        </table>
    </div>
</div>